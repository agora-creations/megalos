{
  "name": "mikros",
  "description": "mikros workflow — hooks, skills, and agents for Gemini CLI",
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "command": "bash .claude/hooks/pre-tool-use.sh"
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "command": "bash .claude/hooks/post-edit.sh"
      }
    ]
  },
  "skills": [
    {
      "path": "skills/simplicity-guard/",
      "description": "Enforces mikros anti-bloat rules"
    }
  ],
  "agents": [
    {
      "path": "agents/phase-builder",
      "description": "Task executor subagent for mikros slices"
    }
  ],
  "commands": [
    "discuss",
    "plan-slice",
    "execute-task",
    "sniff-test",
    "compress"
  ]
}
