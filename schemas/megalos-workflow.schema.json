{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/agora-creations/megalos/main/schemas/megalos-workflow.schema.json",
  "title": "Megalos Workflow",
  "description": "Structural schema for a megálos workflow YAML. Covers parse-time constraints expressible in JSON Schema. Cross-step reference checks (precondition forward-refs, branch target existence, call target existence, call cycles, inject_context source existence) are not expressible here — they are enforced at load time by megalos_server.validate. See megalos_server/SCHEMA.md for the authoritative prose reference.",
  "type": "object",
  "required": ["name", "description", "category", "output_format", "steps"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema spec version this workflow targets. Optional; defaults to \"0.4\"."
    },
    "name": {
      "type": "string",
      "description": "Short identifier for the workflow (e.g. 'coding', 'essay')."
    },
    "description": {
      "type": "string",
      "description": "One-line summary of what the workflow guides."
    },
    "category": {
      "type": "string",
      "description": "Grouping tag (e.g. 'professional', 'writing_communication')."
    },
    "output_format": {
      "type": "string",
      "description": "Expected output type (e.g. 'text', 'structured_code')."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of step mappings.",
      "items": { "$ref": "#/$defs/Step" }
    },
    "conversation_repair": {
      "type": "object",
      "description": "Optional overrides for default repair-behavior strings. Unrecognized keys rejected at load time.",
      "additionalProperties": false,
      "properties": {
        "on_go_back": { "type": "string" },
        "on_cancel": { "type": "string" },
        "on_digression": { "type": "string" },
        "on_clarification": { "type": "string" }
      }
    },
    "guardrails": {
      "type": "array",
      "description": "Workflow-level mechanical triggers.",
      "items": { "$ref": "#/$defs/Guardrail" }
    }
  },
  "$defs": {
    "RefPath": {
      "type": "string",
      "description": "ref-path grammar: step_data.<segment>[.<segment>...]; each segment matches [A-Za-z_][A-Za-z0-9_-]*.",
      "pattern": "^step_data\\.[A-Za-z_][A-Za-z0-9_-]*(\\.[A-Za-z_][A-Za-z0-9_-]*)*$"
    },
    "LiteralNoInterp": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "\\$\\{" },
      "description": "Non-empty literal string; must not contain '${' (interpolations rejected)."
    },
    "Step": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/$defs/LLMStep" },
        { "$ref": "#/$defs/McpToolCallStep" }
      ]
    },
    "LLMStep": {
      "type": "object",
      "description": "Standard LLM-driven workflow step.",
      "required": ["id", "title", "directive_template", "gates", "anti_patterns"],
      "not": {
        "properties": { "action": { "const": "mcp_tool_call" } },
        "required": ["action"]
      },
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "directive_template": { "type": "string", "minLength": 1 },
        "gates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "anti_patterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "step_description": { "type": "string" },
        "collect": { "type": "boolean" },
        "output_schema": {
          "type": "object",
          "description": "JSON Schema object validating the LLM's submission content."
        },
        "max_retries": { "type": "integer", "minimum": 1 },
        "validation_hint": { "type": "string" },
        "inject_context": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from"],
            "properties": {
              "from": { "type": "string" },
              "fields": {
                "type": "array",
                "items": { "type": "string" }
              },
              "summary": { "type": "boolean" }
            }
          }
        },
        "branches": {
          "type": "array",
          "items": { "$ref": "#/$defs/Branch" }
        },
        "default_branch": { "type": "string" },
        "precondition": { "$ref": "#/$defs/Precondition" },
        "call": { "type": "string", "minLength": 1 },
        "call_context_from": { "$ref": "#/$defs/RefPath" },
        "directives": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tone": { "type": "string" },
            "strategy": { "type": "string" },
            "persona": { "type": "string" },
            "constraints": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "intermediate_artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/IntermediateArtifact" }
        },
        "output_from": { "type": "string" }
      },
      "allOf": [
        {
          "description": "collect: true requires output_schema on the same step.",
          "if": { "properties": { "collect": { "const": true } }, "required": ["collect"] },
          "then": { "required": ["output_schema"] }
        },
        {
          "description": "call_context_from requires call on the same step.",
          "if": { "required": ["call_context_from"] },
          "then": { "required": ["call"] }
        },
        {
          "description": "call + collect: true rejected (mutex, code: call_with_collect).",
          "if": {
            "required": ["call"],
            "properties": { "collect": { "const": true } }
          },
          "then": { "not": { "required": ["collect"] } }
        },
        {
          "description": "call + intermediate_artifacts rejected (mutex, code: call_with_intermediate_artifacts).",
          "if": { "required": ["call"] },
          "then": { "not": { "required": ["intermediate_artifacts"] } }
        },
        {
          "description": "call + branches without default_branch rejected (code: call_branches_without_default).",
          "if": {
            "required": ["call", "branches"]
          },
          "then": { "required": ["default_branch"] }
        },
        {
          "description": "output_from requires intermediate_artifacts on the same step.",
          "if": { "required": ["output_from"] },
          "then": { "required": ["intermediate_artifacts"] }
        }
      ]
    },
    "McpToolCallStep": {
      "type": "object",
      "description": "Non-LLM step that invokes an external MCP server tool. The directive_template / gates / anti_patterns trio is replaced by server + tool + args.",
      "required": ["id", "title", "action", "server", "tool", "args"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "action": { "const": "mcp_tool_call" },
        "server": { "$ref": "#/$defs/LiteralNoInterp" },
        "tool": { "$ref": "#/$defs/LiteralNoInterp" },
        "args": { "type": "object" },
        "timeout": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Per-call timeout in seconds. Booleans rejected at load time."
        },
        "step_description": { "type": "string" },
        "precondition": { "$ref": "#/$defs/Precondition" },
        "branches": {
          "type": "array",
          "items": { "$ref": "#/$defs/Branch" }
        },
        "default_branch": { "type": "string" }
      }
    },
    "Precondition": {
      "type": "object",
      "description": "Exactly one of when_equals or when_present; no compound predicates.",
      "oneOf": [
        {
          "required": ["when_equals"],
          "not": { "required": ["when_present"] },
          "properties": {
            "when_equals": {
              "type": "object",
              "required": ["ref", "value"],
              "additionalProperties": false,
              "properties": {
                "ref": { "$ref": "#/$defs/RefPath" },
                "value": {}
              }
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["when_present"],
          "not": { "required": ["when_equals"] },
          "properties": {
            "when_present": { "$ref": "#/$defs/RefPath" }
          },
          "additionalProperties": false
        }
      ]
    },
    "Branch": {
      "type": "object",
      "required": ["next", "condition"],
      "properties": {
        "next": { "type": "string" },
        "condition": { "type": "string" }
      }
    },
    "Guardrail": {
      "type": "object",
      "required": ["id", "trigger", "action", "message"],
      "properties": {
        "id": { "type": "string" },
        "trigger": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "enum": ["keyword_match", "step_count", "step_revisit", "output_length"]
            }
          }
        },
        "action": {
          "enum": ["warn", "force_branch", "escalate"]
        },
        "message": { "type": "string" },
        "target_step": { "type": "string" }
      },
      "allOf": [
        {
          "description": "force_branch action requires target_step.",
          "if": {
            "properties": { "action": { "const": "force_branch" } },
            "required": ["action"]
          },
          "then": { "required": ["target_step"] }
        }
      ]
    },
    "IntermediateArtifact": {
      "type": "object",
      "required": ["id", "description", "schema"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "schema": { "type": "object" },
        "checkpoint": { "type": "boolean" }
      }
    }
  }
}
